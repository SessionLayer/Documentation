# Quickstart node sshd. Cert-only, non-root, SFTP enabled, VERBOSE logging so
# the cert key-id (session id + identity) appears in the node-local log.
Port 22
AddressFamily any

HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_ecdsa_key
HostKey /etc/ssh/ssh_host_rsa_key

LogLevel VERBOSE

# Access is short-lived certs only — no passwords, no root.
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes

# The crux (Design §3.2): the node trusts ONLY the session CA. The presented
# user certificate must be signed by this CA and carry a principal == the login.
TrustedUserCAKeys /etc/ssh/trusted_user_ca.pub
AuthorizedKeysFile .ssh/authorized_keys

Subsystem sftp internal-sftp

UsePAM no
AllowUsers deploy dba
AcceptEnv LANG LC_*
